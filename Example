-- Chilly authorized integration demo
-- Replace the two URLs after uploading/publishing the enhanced files.
-- This demo intentionally contains UI/dev-tool examples only.

if not game:IsLoaded() then
    game.Loaded:Wait()
end

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local Stats = game:GetService("Stats")

local LocalPlayer = Players.LocalPlayer

local UI_URL = "https://raw.githubusercontent.com/lvkrhch/Chilly-UI/refs/heads/main/Chilly%20UI"
local ASSETS_URL = "https://raw.githubusercontent.com/lvkrhch/Chilly-UI/refs/heads/main/Assets"

local Chilly = loadstring(game:HttpGet(UI_URL))()
local Assets = loadstring(game:HttpGet(ASSETS_URL))()
Chilly:LoadAssets(Assets)
Chilly:InstallRayfieldAlias()

local Window = Chilly:CreateProfessionalWindow({
    Name = "Chilly",
    Icon = "dashboard",
    LoadingTitle = "Chilly",
    LoadingSubtitle = "Professional UI ready",
    ShowText = "Chilly",
    ToggleUIKeybind = "K",
    ConfigurationSaving = {
        Enabled = true,
        FolderName = "Chilly",
        FileName = "Chilly_Authorized_Config",
    },
})

local DashboardTab = Window:CreateTab("Dashboard", "dashboard")
local InterfaceTab = Window:CreateTab("Interface", "palette")
local ToolsTab = Window:CreateTab("Tools", "wrench")
local LogsTab = Window:CreateTab("Logs", "terminal")

DashboardTab:CreateHeader({
    Title = "Runtime Overview",
    Content = "Lightweight dashboard for authorized Roblox experiences.",
})

local fpsStat = DashboardTab:CreateStat({
    Name = "FPS",
    Range = {0, 240},
    Value = 60,
    Color = Color3.fromRGB(75, 162, 255),
})

local pingStat = DashboardTab:CreateStat({
    Name = "Network Ping",
    Range = {0, 400},
    Value = 0,
    Color = Color3.fromRGB(66, 226, 171),
})

DashboardTab:CreateNotice({
    Level = "info",
    Title = "Authorized use",
    Content = "Keep gameplay logic inside experiences you own or have permission to test.",
})

InterfaceTab:CreateThemePreview({Theme = "Graphite"})
InterfaceTab:CreateThemePreview({Theme = "Aurora"})
InterfaceTab:CreateThemePreview({Theme = "Studio"})

InterfaceTab:CreateSegmentedControl({
    Name = "UI Density",
    Options = {"Comfortable", "Compact", "Spacious"},
    CurrentOption = "Comfortable",
    Flag = "Chilly_Density",
})

InterfaceTab:CreateStepper({
    Name = "Animation Speed",
    Range = {50, 150},
    Increment = 5,
    CurrentValue = 100,
    Suffix = "%",
    Flag = "Chilly_AnimationSpeed",
})

ToolsTab:CreateQuickActions({
    Name = "Session",
    Actions = {
        {
            Name = "Notify",
            Primary = true,
            Callback = function()
                Chilly:Notify({
                    Title = "Chilly",
                    Content = "Enhanced UI is running.",
                    Duration = 3,
                    Image = "sparkles",
                })
            end,
        },
        {
            Name = "Save",
            Callback = function()
                Chilly:SaveConfiguration()
            end,
        },
        {
            Name = "Hide",
            Callback = function()
                Chilly:SetVisibility(false)
            end,
        },
    },
})

ToolsTab:CreateInput({
    Name = "Player Note",
    PlaceholderText = "Write a local note",
    RemoveTextAfterFocusLost = false,
    Flag = "Chilly_PlayerNote",
})

ToolsTab:CreateToggle({
    Name = "Show Notifications",
    CurrentValue = true,
    Flag = "Chilly_ShowNotifications",
})

local console = LogsTab:CreateMiniConsole({
    Height = 180,
    Text = "Chilly console initialized.",
})

LogsTab:CreateQuickActions({
    Name = "Console",
    Actions = {
        {
            Name = "Append",
            Primary = true,
            Callback = function()
                console:Append("Player: " .. (LocalPlayer and LocalPlayer.Name or "Unknown"))
            end,
        },
        {
            Name = "Clear",
            Callback = function()
                console:Clear()
            end,
        },
    },
})

local frames = 0
local elapsed = 0
RunService.RenderStepped:Connect(function(delta)
    frames += 1
    elapsed += delta
    if elapsed >= 1 then
        fpsStat:Set(frames)
        frames = 0
        elapsed = 0
        local ping = 0
        pcall(function()
            ping = Stats.Network.ServerStatsItem["Data Ping"]:GetValue()
        end)
        pingStat:Set(math.clamp(math.floor(ping + 0.5), 0, 400))
    end
end)
