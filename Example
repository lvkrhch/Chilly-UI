local Chilly = loadstring(game:HttpGet("https://raw.githubusercontent.com/lvkrhch/Chilly-UI/main/Chilly%20UI"))()

pcall(function()
    local Assets = loadstring(game:HttpGet("https://raw.githubusercontent.com/lvkrhch/Chilly-UI/main/ChillyAssets.lua"))()
    Chilly:LoadAssets(Assets)
end)

local Window = Chilly:CreateWindow({
    Name = "Chilly by Khai",
    Icon = "snowflake",
    LoadingTitle = "Chilly Interface Suite",
    LoadingSubtitle = "by Khai",
    ShowText = "Chilly",
    Theme = "Chilly",
    ToggleUIKeybind = "K",
    DisableLoadingAnimation = false,
    LoadingDuration = 2.2,
    ConfigurationSaving = {
        Enabled = true,
        FolderName = "Chilly",
        FileName = "ExampleConfig",
    },
    Discord = {
        Enabled = false,
        Invite = "yourinvite",
        RememberJoins = true,
    },
    KeySystem = false,
    KeySettings = {
        Title = "Chilly Key",
        Subtitle = "Private access",
        Note = "Enter your key.",
        FileName = "ChillyKey",
        SaveKey = true,
        Key = {"Khai"},
    },
})

local Main = Window:CreateTab("Main", "home")
local Player = Window:CreateTab("Player", "user-round")
local Settings = Window:CreateTab("Settings", "settings")

Main:CreateSection("Basic")

Main:CreateProgress({
    Name = "Boot Quality",
    Range = {0, 100},
    CurrentValue = 92,
})

Main:CreateButton({
    Name = "Say Hello",
    Callback = function()
        Chilly:Notify({
            Title = "Chilly",
            Content = "Hello from Chilly by Khai.",
            Duration = 4,
        })
    end,
})

Main:CreateActionRow({
    Name = "Quick Tools",
    Actions = {
        {
            Name = "Notify",
            Primary = true,
            Callback = function()
                Chilly:Notify({
                    Title = "Professional",
                    Content = "Action row works cleanly.",
                    Duration = 3,
                    Actions = {
                        {Name = "OK", Callback = function() print("OK") end},
                    },
                })
            end,
        },
        {
            Name = "Print",
            Callback = function()
                print("Chilly action row clicked")
            end,
        },
    },
})

Main:CreateToggle({
    Name = "Auto Farm",
    CurrentValue = false,
    Flag = "AutoFarm",
    Callback = function(value)
        print("Auto Farm:", value)
    end,
})

Main:CreateSlider({
    Name = "Farm Delay",
    Range = {0, 10},
    Increment = 0.5,
    Suffix = "s",
    CurrentValue = 2,
    Flag = "FarmDelay",
    Callback = function(value)
        print("Delay:", value)
    end,
})

Main:CreateDropdown({
    Name = "Target Mode",
    Options = {"Nearest", "Lowest HP", "Highest Value"},
    CurrentOption = "Nearest",
    Flag = "TargetMode",
    Callback = function(option)
        print("Target:", option)
    end,
})

Main:CreateDropdown({
    Name = "Multi Select",
    Options = {"Coins", "Gems", "Drops", "Quests"},
    CurrentOption = {"Coins"},
    MultipleOptions = true,
    Flag = "LootTypes",
    Callback = function(options)
        print("Loot:", table.concat(options, ", "))
    end,
})

Player:CreateSection("Movement")

Player:CreateSlider({
    Name = "WalkSpeed",
    Range = {16, 200},
    Increment = 1,
    Suffix = "studs",
    CurrentValue = 16,
    Flag = "WalkSpeed",
    Callback = function(value)
        local character = game.Players.LocalPlayer.Character
        local humanoid = character and character:FindFirstChildOfClass("Humanoid")
        if humanoid then
            humanoid.WalkSpeed = value
        end
    end,
})

Player:CreateInput({
    Name = "Custom Message",
    CurrentValue = "",
    PlaceholderText = "Type here",
    RemoveTextAfterFocusLost = false,
    Flag = "Message",
    Callback = function(text)
        print("Message:", text)
    end,
})

Player:CreateColorPicker({
    Name = "ESP Color",
    Color = Color3.fromRGB(85, 158, 255),
    Flag = "EspColor",
    Callback = function(color)
        print("Color:", color)
    end,
})

Player:CreateKeybind({
    Name = "Quick Action",
    CurrentKeybind = "Q",
    HoldToInteract = false,
    Flag = "QuickAction",
    Callback = function()
        Chilly:Notify({
            Title = "Keybind",
            Content = "Quick Action pressed.",
            Duration = 2,
        })
    end,
})

Settings:CreateSection("Information")

local Status = Settings:CreateLabel("Status: ready", "badge-check")

Settings:CreateParagraph({
    Title = "About",
    Content = "Chilly by Khai is a deep-blue macOS-style Roblox UI library with a Rayfield-style API.",
})

Settings:CreateCode({
    Height = 110,
    Code = "print('Chilly by Khai')\n-- Toggle UI: K\n-- Clean layer, no screen-blocking shadow",
})

Settings:CreateDivider()

Settings:CreateButton({
    Name = "Set Status",
    Callback = function()
        Status:Set("Status: updated")
    end,
})

Settings:CreateButton({
    Name = "Destroy UI",
    Callback = function()
        Chilly:Destroy()
    end,
})
