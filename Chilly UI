local function safeCall(callback, ...)
    if type(callback) == "function" then
        local ok, err = pcall(callback, ...)
        if not ok then
            warn("[Chilly] callback error:", err)
        end
    end
end

local function tween(instance, properties, duration, style, direction)
    local info = TweenInfo.new(duration or 0.18, style or Enum.EasingStyle.Quart, direction or Enum.EasingDirection.Out)
    local created = TweenService:Create(instance, info, properties)
    created:Play()
    return created
end

local function make(className, properties, children)
    local instance = Instance.new(className)
    for key, value in pairs(properties or {}) do
        instance[key] = value
    end
    for _, child in ipairs(children or {}) do
        child.Parent = instance
    end
    return instance
end

local function setZIndexTree(instance, zIndex)
    if instance:IsA("GuiObject") then
        instance.ZIndex = zIndex
    end
    for _, child in ipairs(instance:GetDescendants()) do
        if child:IsA("GuiObject") then
            child.ZIndex = zIndex
        end
    end
end

local function bindClick(button, callback)
    if button:IsA("GuiButton") then
        button.Active = true
        button.AutoButtonColor = false
    end
    button.MouseButton1Click:Connect(function()
        safeCall(callback)
    end)
end

