local function iconText(icon)
    if icon == nil or icon == 0 then
        return ""
    end
    if type(icon) == "number" then
        return ""
    end
    local mapped = Chilly.Assets.Icons[string.lower(tostring(icon))]
    if type(mapped) == "string" and #mapped == 1 then
        return mapped
    end
    return string.upper(string.sub(tostring(icon), 1, 1))
end

local function resolveImageAsset(icon)
    if not Chilly.Assets.UseImages then
        return nil
    end
    if type(icon) == "number" and icon ~= 0 then
        return {
            Image = "rbxassetid://" .. tostring(icon),
            RectOffset = Vector2.new(0, 0),
            RectSize = Vector2.new(0, 0),
        }
    end
    if type(icon) ~= "string" then
        return nil
    end

    local mapped = Chilly.Assets.Images[icon] or Chilly.Assets.Images[string.lower(icon)]
    if type(mapped) == "number" then
        return {
            Image = "rbxassetid://" .. tostring(mapped),
            RectOffset = Vector2.new(0, 0),
            RectSize = Vector2.new(0, 0),
        }
    elseif type(mapped) == "table" then
        return {
            Image = mapped.Image or mapped.Url or (mapped.Id and ("rbxassetid://" .. tostring(mapped.Id))),
            RectOffset = mapped.ImageRectOffset or mapped.RectOffset or Vector2.new(0, 0),
            RectSize = mapped.ImageRectSize or mapped.RectSize or Vector2.new(0, 0),
        }
    end

    if Chilly.Lucide then
        local lucideName = Chilly.Assets.Icons[string.lower(icon)]
        if type(lucideName) ~= "string" then
            lucideName = string.lower(icon)
        end
        local ok, asset = pcall(function()
            return Chilly.Lucide.GetAsset(lucideName, 48)
        end)
        if ok and asset then
            return {
                Image = asset.Url or (asset.Id and ("rbxassetid://" .. tostring(asset.Id))),
                RectOffset = asset.ImageRectOffset or Vector2.new(0, 0),
                RectSize = asset.ImageRectSize or Vector2.new(0, 0),
            }
        end
    end

    return nil
end

local function makeIcon(icon, properties)
    properties = properties or {}
    local asset = resolveImageAsset(icon)
    if asset and asset.Image then
        local imageProperties = {}
        for key, value in pairs(properties) do
            if key ~= "TextColor3" and key ~= "TextSize" and key ~= "Font" and key ~= "Text" then
                imageProperties[key] = value
            end
        end
        local image = make("ImageLabel", deepMerge({
            Name = "Icon",
            BackgroundTransparency = 1,
            Image = asset.Image,
            ImageColor3 = properties.ImageColor3 or properties.TextColor3 or Color3.fromRGB(255, 255, 255),
            ScaleType = Enum.ScaleType.Fit,
            ImageRectOffset = asset.RectOffset,
            ImageRectSize = asset.RectSize,
        }, imageProperties))
        return image
    end
    local textProperties = {}
    for key, value in pairs(properties) do
        if key ~= "ImageColor3" and key ~= "ImageRectOffset" and key ~= "ImageRectSize" and key ~= "ScaleType" and key ~= "Image" then
            textProperties[key] = value
        end
    end
    return make("TextLabel", deepMerge({
        Name = "Icon",
        BackgroundTransparency = 1,
        Font = Enum.Font.GothamBold,
        Text = iconText(icon),
        TextColor3 = properties.TextColor3 or Color3.fromRGB(255, 255, 255),
        TextSize = properties.TextSize or 13,
    }, textProperties))
end

