            FillDirection = Enum.FillDirection.Horizontal,
            Padding = UDim.new(0, 8),
            SortOrder = Enum.SortOrder.LayoutOrder,
            HorizontalAlignment = Enum.HorizontalAlignment.Right,
            VerticalAlignment = Enum.VerticalAlignment.Center,
        }),
    })
    local object = {Frame = frame, Buttons = {}}
    for _, action in ipairs(actions) do
        local button = make("TextButton", {
            Size = UDim2.new(0, math.clamp(string.len(tostring(action.Name or "Action")) * 8 + 28, 82, 150), 0, 34),
            BackgroundColor3 = action.Primary and self.Theme.Accent or self.Theme.InputBackground,
            Font = Enum.Font.GothamSemibold,
            Text = tostring(action.Name or "Action"),
            TextColor3 = self.Theme.TextColor,
            TextSize = 12,
            Active = true,
            AutoButtonColor = false,
            Parent = row,
        }, {
            corner(8),
            stroke(action.Primary and self.Theme.SliderStroke or self.Theme.InputStroke, 1, 0.25),
        })
        bindClick(button, action.Callback)
        table.insert(object.Buttons, button)
    end
    function object:Destroy()
        frame:Destroy()
    end
    return object
end

function Tab:CreateCode(options)
    options = options or {}
    local frame = self:ElementFrame(options.Height or 120)
    local box = make("TextBox", {
        Position = UDim2.new(0, 14, 0, 12),
        Size = UDim2.new(1, -28, 1, -24),
        BackgroundColor3 = self.Theme.InputBackground,
        Font = Enum.Font.Code,
        Text = options.Code or options.Content or "",
        TextColor3 = self.Theme.TextColor,
        TextSize = 12,
        TextXAlignment = Enum.TextXAlignment.Left,
        TextYAlignment = Enum.TextYAlignment.Top,
        ClearTextOnFocus = false,
        MultiLine = true,
        Active = true,
        Parent = frame,
    }, {
        corner(8),
        stroke(self.Theme.InputStroke, 1, 0.25),
        padding(10, 10, 8, 8),
    })
    local object = {Frame = frame, Box = box}
    function object:Set(text)
        box.Text = tostring(text)
    end
    function object:Get()
        return box.Text
    end
    function object:Destroy()
        frame:Destroy()
    end
    return object
end

function Tab:CreateTextbox(options)
    return self:CreateInput(options)
end

function Tab:CreateCheckbox(options)
    return self:CreateToggle(options)
end

function Tab:CreateBind(options)
    return self:CreateKeybind(options)
end

function Tab:CreateCard(options)
    return self:CreateParagraph(options)
end

return Chilly
