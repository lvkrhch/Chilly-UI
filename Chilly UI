function Tab:CreateDropdown(options)
    options = options or {}
    local window = self.Window
    local flag = options.Flag
    local multi = options.MultipleOptions == true or options.MultiSelection == true
    local selected = Chilly.Flags[flag] or options.CurrentOption or (multi and {} or nil)
    if not multi and type(selected) == "table" then
        selected = selected[1]
    end
    if multi and type(selected) ~= "table" then
        selected = selected and {selected} or {}
    end
    flagValue(flag, selected)

    local frame = self:ElementFrame(52)
    local label = make("TextLabel", {
        Position = UDim2.new(0, 14, 0, 0),
        Size = UDim2.new(1, -100, 1, 0),
        BackgroundTransparency = 1,
        Font = Enum.Font.GothamSemibold,
        Text = options.Name or "Dropdown",
        TextColor3 = self.Theme.TextColor,
        TextSize = 13,
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = frame,
    })
    local openButton = make("TextButton", {
        AnchorPoint = Vector2.new(1, 0.5),
        Position = UDim2.new(1, -14, 0.5, 0),
        Size = UDim2.new(0, 150, 0, 32),
        BackgroundColor3 = self.Theme.InputBackground,
        Font = Enum.Font.Gotham,
        Text = "...",
        TextColor3 = self.Theme.MutedText,
        TextSize = 12,
        Active = true,
        AutoButtonColor = false,
        Parent = frame,
    }, {
        corner(8),
        stroke(self.Theme.ElementStroke, 1, 0.2),
    })
    local list = make("Frame", {
        Position = UDim2.new(0, 14, 0, 52),
        Size = UDim2.new(1, -28, 0, 0),
        BackgroundColor3 = self.Theme.SecondaryElementBackground,
        ClipsDescendants = true,
        Visible = false,
        Parent = frame,
    }, {
        corner(8),
        padding(6, 6, 6, 6),
        listLayout(6, Enum.HorizontalAlignment.Center),
    })

    local object = {CurrentOption = selected, Options = options.Options or {}, Frame = frame}
    local expanded = false

    local function contains(tbl, item)
        for _, value in ipairs(tbl) do
            if value == item then
                return true
            end
        end
        return false
    end

    local function selectedText()
        if multi then
            return #object.CurrentOption > 0 and table.concat(object.CurrentOption, ", ") or "Select"
        end
        return object.CurrentOption and tostring(object.CurrentOption) or "Select"
    end

    local function rebuild()
        for _, child in ipairs(list:GetChildren()) do
            if child:IsA("GuiButton") then
                child:Destroy()
            end
        end
        for _, option in ipairs(object.Options) do
            local active = multi and contains(object.CurrentOption, option) or object.CurrentOption == option
            local item = make("TextButton", {
                Size = UDim2.new(1, 0, 0, 30),
                BackgroundColor3 = active and self.Theme.AccentSoft or self.Theme.ElementBackground,
                Font = Enum.Font.Gotham,
                Text = tostring(option),
                TextColor3 = self.Theme.TextColor,
                TextSize = 12,
                Active = true,
                AutoButtonColor = false,
                Parent = list,
            }, {corner(7)})
            item.MouseButton1Click:Connect(function()
                if multi then
                    if contains(object.CurrentOption, option) then
                        for i = #object.CurrentOption, 1, -1 do
                            if object.CurrentOption[i] == option then
                                table.remove(object.CurrentOption, i)
                            end
                        end
                    else
                        table.insert(object.CurrentOption, option)
                    end
                else
                    object.CurrentOption = option
                    expanded = false
                end
                flagValue(flag, object.CurrentOption)
                openButton.Text = selectedText()
                safeCall(options.Callback, object.CurrentOption)
                window:SaveConfiguration()
                rebuild()
                if not multi then
                    list.Visible = false
                    tween(frame, {Size = UDim2.new(1, 0, 0, 52)}, 0.16)
                    tween(list, {Size = UDim2.new(1, -28, 0, 0)}, 0.16)
                end
            end)
        end
    end

    function object:Set(value)
        object.CurrentOption = value
        if multi and type(value) ~= "table" then
            object.CurrentOption = {value}
        end
        if not multi and type(value) == "table" then
            object.CurrentOption = value[1]
        end
        flagValue(flag, object.CurrentOption)
        openButton.Text = selectedText()
        rebuild()
        safeCall(options.Callback, object.CurrentOption)
        window:SaveConfiguration()
    end

    function object:Refresh(newOptions, keepCurrent)
        object.Options = newOptions or {}
        if keepCurrent ~= true then
            object.CurrentOption = multi and {} or nil
        end
        flagValue(flag, object.CurrentOption)
        openButton.Text = selectedText()
        rebuild()
    end

    openButton.MouseButton1Click:Connect(function()
        expanded = not expanded
        list.Visible = true
        local height = expanded and math.min(#object.Options * 36 + 12, 190) or 0
        tween(frame, {Size = UDim2.new(1, 0, 0, 52 + height + (expanded and 10 or 0))}, 0.18)
        tween(list, {Size = UDim2.new(1, -28, 0, height)}, 0.18).Completed:Connect(function()
            if not expanded then
                list.Visible = false
            end
        end)
    end)

    openButton.Text = selectedText()
    rebuild()
    task.defer(function()
        safeCall(options.Callback, object.CurrentOption)
    end)
    return object
end

