        Text = options.Name or "Input",
        TextColor3 = self.Theme.TextColor,
        TextSize = 13,
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = frame,
    })
    local input = make("TextBox", {
        AnchorPoint = Vector2.new(1, 0.5),
        Position = UDim2.new(1, -14, 0.5, 0),
        Size = UDim2.new(0.58, -8, 0, 34),
        BackgroundColor3 = self.Theme.InputBackground,
        Font = Enum.Font.Gotham,
        PlaceholderText = options.PlaceholderText or "",
        PlaceholderColor3 = self.Theme.PlaceholderColor,
        Text = tostring(current),
        TextColor3 = self.Theme.TextColor,
        TextSize = 13,
        ClearTextOnFocus = false,
        Parent = frame,
    }, {
        corner(8),
        stroke(self.Theme.ElementStroke, 1, 0.2),
        padding(10, 10, 0, 0),
    })

    local object = {CurrentValue = current, Frame = frame}
    local function fire()
        local text = input.Text
        if options.NumbersOnly then
            text = text:gsub("[^%d%.%-]", "")
            input.Text = text
        end
        if type(options.CharacterLimit) == "number" and #text > options.CharacterLimit then
            text = string.sub(text, 1, options.CharacterLimit)
            input.Text = text
        end
        object.CurrentValue = text
        flagValue(flag, text)
        safeCall(options.Callback, text)
        window:SaveConfiguration()
        if options.RemoveTextAfterFocusLost then
            input.Text = ""
        end
    end

    input.FocusLost:Connect(function(enter)
        if options.OnEnter and not enter then
            return
        end
        fire()
    end)
    function object:Set(value)
        object.CurrentValue = tostring(value)
        input.Text = object.CurrentValue
        flagValue(flag, object.CurrentValue)
        safeCall(options.Callback, object.CurrentValue)
