local function passKeySystem(settings)
    if not settings or not settings.Enabled then
        return true
    end

    local keySettings = settings.KeySettings or {}
    local keys = keySettings.Key or {}
    local fileName = keySettings.FileName or "ChillyKey"
    local saveKey = keySettings.SaveKey == true
    local folder = "Chilly"
    local path = folder .. "/" .. fileName .. ".key"

    if saveKey and executorSupportsFile() then
        ensureFolder(folder)
        if isfile(path) then
            local saved = readfile(path)
            for _, key in ipairs(keys) do
                if saved == key then
                    return true
                end
            end
        end
    end

    local gui = make("ScreenGui", {
        Name = "ChillyKeySystem",
        ResetOnSpawn = false,
        IgnoreGuiInset = true,
        Parent = getParent(),
    })

    local panel = make("Frame", {
        AnchorPoint = Vector2.new(0.5, 0.5),
        Position = UDim2.new(0.5, 0, 0.5, 0),
        Size = UDim2.new(0, 390, 0, 230),
        BackgroundColor3 = Chilly.Themes.Chilly.Background,
        Parent = gui,
    }, {
        corner(14),
        stroke(Chilly.Themes.Chilly.ElementStroke, 1, 0),
        padding(22, 22, 22, 22),
    })

    make("TextLabel", {
        Size = UDim2.new(1, 0, 0, 28),
        BackgroundTransparency = 1,
        Font = Enum.Font.GothamBold,
        Text = keySettings.Title or "Chilly Key System",
        TextColor3 = Chilly.Themes.Chilly.TextColor,
        TextSize = 20,
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = panel,
    })

    make("TextLabel", {
        Position = UDim2.new(0, 0, 0, 34),
        Size = UDim2.new(1, 0, 0, 42),
        BackgroundTransparency = 1,
        Font = Enum.Font.Gotham,
        Text = keySettings.Note or keySettings.Subtitle or "Enter your key to continue.",
        TextColor3 = Chilly.Themes.Chilly.MutedText,
        TextSize = 13,
        TextWrapped = true,
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = panel,
    })

    local input = make("TextBox", {
        Position = UDim2.new(0, 0, 0, 96),
        Size = UDim2.new(1, 0, 0, 42),
        BackgroundColor3 = Chilly.Themes.Chilly.InputBackground,
        Font = Enum.Font.Gotham,
        PlaceholderText = "Key",
        PlaceholderColor3 = Chilly.Themes.Chilly.PlaceholderColor,
        Text = "",
        TextColor3 = Chilly.Themes.Chilly.TextColor,
        TextSize = 14,
        ClearTextOnFocus = false,
        Parent = panel,
    }, {
        corner(8),
        stroke(Chilly.Themes.Chilly.ElementStroke, 1, 0.2),
        padding(12, 12, 0, 0),
    })

    local submit = make("TextButton", {
        Position = UDim2.new(0, 0, 1, -46),
        Size = UDim2.new(1, 0, 0, 42),
        BackgroundColor3 = Chilly.Themes.Chilly.Accent,
        Font = Enum.Font.GothamSemibold,
        Text = "Continue",
        TextColor3 = Color3.fromRGB(255, 255, 255),
        TextSize = 14,
        Parent = panel,
    }, {
        corner(8),
    })

    local passed = false
    local done = Instance.new("BindableEvent")
    local function check()
        for _, key in ipairs(keys) do
            if input.Text == key then
                passed = true
                if saveKey and executorSupportsFile() then
                    ensureFolder(folder)
                    writefile(path, input.Text)
                end
                done:Fire()
                return
            end
        end
        input.Text = ""
        input.PlaceholderText = "Wrong key"
        tween(input, {BackgroundColor3 = Color3.fromRGB(56, 20, 32)}, 0.12)
        task.delay(0.4, function()
            if input.Parent then
                tween(input, {BackgroundColor3 = Chilly.Themes.Chilly.InputBackground}, 0.18)
            end
        end)
    end

    submit.MouseButton1Click:Connect(check)
    input.FocusLost:Connect(function(enter)
        if enter then
            check()
        end
    end)

    done.Event:Wait()
    done:Destroy()
    gui:Destroy()
    return passed
end

