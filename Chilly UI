function Window:SelectTab(tab)
    for _, other in ipairs(self.Tabs) do
        local active = other == tab
        other.Page.Visible = active
        tween(other.Button, {
            BackgroundColor3 = active and self.Theme.AccentSoft or self.Theme.SecondaryElementBackground,
            TextColor3 = active and self.Theme.TextColor or self.Theme.MutedText,
        }, 0.16)
        for _, child in ipairs(other.Button:GetChildren()) do
            if child:IsA("TextLabel") then
                tween(child, {TextColor3 = active and self.Theme.TextColor or self.Theme.MutedText}, 0.16)
            elseif child:IsA("ImageLabel") then
                tween(child, {ImageColor3 = active and self.Theme.TextColor or self.Theme.MutedText}, 0.16)
            end
        end
    end
    self.ActiveTab = tab
end

