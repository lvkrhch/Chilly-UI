local function iconName(icon)
    if icon == nil or icon == 0 then
        return nil
    end
    if type(icon) == "number" then
        return nil
    end
    local key = string.lower(tostring(icon))
    return key
end

local function normalizeKey(key)
    if typeof(key) == "EnumItem" then
        return key
    end
    if type(key) == "string" and Enum.KeyCode[key] then
        return Enum.KeyCode[key]
    end
    return Enum.KeyCode.RightControl
end

local function getParent()
    local playerGui = LocalPlayer and LocalPlayer:FindFirstChildOfClass("PlayerGui")
    if not playerGui and LocalPlayer then
        playerGui = LocalPlayer:WaitForChild("PlayerGui")
    end

    local ok, coreGui = pcall(function()
        return game:GetService("CoreGui")
    end)
    if ok and coreGui then
        local probe = Instance.new("ScreenGui")
        probe.Name = "ChillyParentProbe"
        local canUseCoreGui = pcall(function()
            probe.Parent = coreGui
        end)
        probe:Destroy()
        if canUseCoreGui then
            return coreGui
        end
    end

    return playerGui
end

local function executorSupportsFile()
    return type(writefile) == "function"
        and type(readfile) == "function"
        and type(isfile) == "function"
        and type(makefolder) == "function"
        and type(isfolder) == "function"
end

local function ensureFolder(path)
    if type(isfolder) == "function" and not isfolder(path) then
        makefolder(path)
    end
end

local function deepMerge(base, override)
    local merged = {}
    for key, value in pairs(base) do
        merged[key] = value
    end
    for key, value in pairs(override or {}) do
        merged[key] = value
    end
    return merged
end

local function colorToTable(color)
    return {
        R = math.floor(color.R * 255 + 0.5),
        G = math.floor(color.G * 255 + 0.5),
        B = math.floor(color.B * 255 + 0.5),
    }
end

local function tableToColor(value, fallback)
    if type(value) == "table" and value.R and value.G and value.B then
        return Color3.fromRGB(value.R, value.G, value.B)
    end
    return fallback
end

