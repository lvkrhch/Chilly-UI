function Tab:CreateKeybind(options)
    options = options or {}
    local key = normalizeKey(options.CurrentKeybind or options.CurrentKey or options.Key or Enum.KeyCode.RightControl)
    local button = self:CreateButton({Name = (options.Name or "Keybind") .. ": " .. key.Name})
    local waiting = false
    function button:Set(newKey)
        key = normalizeKey(newKey)
        self.Button.Text = (options.Name or "Keybind") .. ": " .. key.Name
        if options.Flag then
            Chilly.Flags[options.Flag] = key.Name
        end
    end
    connect(self.Window, button.Button.MouseButton1Click, function()
        waiting = true
        button.Button.Text = "Press a key..."
    end)
    connect(self.Window, UserInputService.InputBegan, function(input, gameProcessed)
        if gameProcessed then
            return
        end
        local pressed = input.KeyCode ~= Enum.KeyCode.Unknown and input.KeyCode or input.UserInputType
        if waiting then
            waiting = false
            button:Set(pressed)
            return
        end
        if pressed == key then
            call(options.Callback, key)
        end
    end)
    button.CurrentKeybind = key
    return button
end

