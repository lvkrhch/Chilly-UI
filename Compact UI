local function buildTheme(theme)
    local result = {}
    local source = type(theme) == "string" and Chilly.Themes[theme] or theme
    for key, value in pairs(baseTheme) do
        result[key] = value
    end
    for key, value in pairs(source or {}) do
        result[key] = value
    end
    return result
end

function Chilly:CreateTheme(name, overrides)
    self.Themes[name] = buildTheme(overrides or self.ThemePresets[name])
    return self.Themes[name]
end

Chilly:CreateTheme("Graphite", Chilly.ThemePresets.Graphite)
Chilly:CreateTheme("Slate", Chilly.ThemePresets.Slate)
