function Tab:CreateDropdown(options)
    options = options or {}
    local frame = component(self, 44)
    local choices = asTextList(options.Options or options.Values or {})
    local multi = options.MultipleOptions or options.Multi
    local selected = multi and {} or tostring(options.CurrentOption or options.CurrentValue or choices[1] or "")
    local button = buttonLike(frame, self.Theme, "", 30)
    button.Size = UDim2.new(1, 0, 0, 30)
    button.Position = UDim2.fromOffset(0, 0)
    local list = make("Frame", {
        BackgroundColor3 = self.Theme.Panel2,
        Visible = false,
        Position = UDim2.new(0, 0, 1, 4),
        Size = UDim2.new(1, 0, 0, math.min(#choices, 5) * 30),
        ZIndex = 5,
        Parent = frame,
    })
    addCorner(list, 6)
    make("UIListLayout", {SortOrder = Enum.SortOrder.LayoutOrder, Parent = list})

    local object = {Frame = frame, Button = button, Options = choices, CurrentOption = selected}
    local function textForSelection()
        return options.Name and (options.Name .. ": " .. (multi and table.concat(selected, ", ") or tostring(selected))) or tostring(multi and table.concat(selected, ", ") or selected)
    end
    local function rebuild()
        list:ClearAllChildren()
        make("UIListLayout", {SortOrder = Enum.SortOrder.LayoutOrder, Parent = list})
        list.Size = UDim2.new(1, 0, 0, math.min(#object.Options, 5) * 30)
        for _, choice in ipairs(object.Options) do
            local row = buttonLike(list, self.Theme, choice, 30)
            row.ZIndex = 6
            connect(self.Window, row.MouseButton1Click, function()
                object:Set(choice)
                if not multi then
                    list.Visible = false
                    frame.Size = UDim2.new(1, 0, 0, 44)
                end
            end)
        end
    end
    function object:Set(value)
        if multi then
            local index = table.find(selected, tostring(value))
            if index then
                table.remove(selected, index)
            else
                table.insert(selected, tostring(value))
            end
        else
            selected = tostring(value or "")
        end
        self.CurrentOption = selected
        button.Text = textForSelection()
        if options.Flag then
            Chilly.Flags[options.Flag] = selected
        end
        call(options.Callback, selected)
    end
    function object:Refresh(newOptions, keepCurrent)
        self.Options = asTextList(newOptions or {})
        if not keepCurrent then
            selected = multi and {} or (self.Options[1] or "")
        end
        rebuild()
        button.Text = textForSelection()
    end
    connect(self.Window, button.MouseButton1Click, function()
        list.Visible = not list.Visible
        frame.Size = list.Visible and UDim2.new(1, 0, 0, 50 + list.Size.Y.Offset) or UDim2.new(1, 0, 0, 44)
        resizeCanvas(self.Page)
    end)
    rebuild()
    button.Text = textForSelection()
    return object
end

