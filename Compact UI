-- Chilly UI Compact
-- Shorter Rayfield-style Roblox UI library. Core API kept, decorative bloat removed.

local Chilly = {
    Name = "Chilly",
    Version = "2.1.0-compact",
    Flags = {},
    Themes = {},
    Windows = {},
    Connections = {},
    IconCatalog = {},
    ToggleUIKeybind = Enum.KeyCode.Insert,
    OverlayDisplayOrder = 2147483647,
}

local Players = game:GetService("Players")
local TweenService = game:GetService("TweenService")
local UserInputService = game:GetService("UserInputService")
local HttpService = game:GetService("HttpService")

local LocalPlayer = Players.LocalPlayer

local function call(fn, ...)
    if type(fn) == "function" then
        local ok, err = pcall(fn, ...)
        if not ok then
            warn("[Chilly] callback error:", err)
        end
    end
end

local function make(className, props, children)
    local item = Instance.new(className)
    for key, value in pairs(props or {}) do
        item[key] = value
    end
    for _, child in ipairs(children or {}) do
        child.Parent = item
    end
    return item
end

local function tween(item, props, time)
    local info = TweenInfo.new(time or 0.15, Enum.EasingStyle.Quart, Enum.EasingDirection.Out)
    local created = TweenService:Create(item, info, props)
    created:Play()
    return created
end

local function addCorner(parent, radius)
    make("UICorner", {CornerRadius = UDim.new(0, radius or 6), Parent = parent})
end

local function addStroke(parent, color, alpha)
    make("UIStroke", {
        Color = color,
        Transparency = alpha or 0,
        Thickness = 1,
        ApplyStrokeMode = Enum.ApplyStrokeMode.Border,
        Parent = parent,
    })
end

local function canParentToCoreGui()
    local ok, coreGui = pcall(function()
        return game:GetService("CoreGui")
    end)
    if not ok or not coreGui then
        return false, nil
    end

    local probe = Instance.new("ScreenGui")
    probe.Name = "ChillyOverlayProbe"
    local canUseCore = pcall(function()
        probe.Parent = coreGui
    end)
    probe:Destroy()
    return canUseCore, coreGui
end

local function getParent(preferPlayerGui)
    if not preferPlayerGui then
        local canUseCore, coreGui = canParentToCoreGui()
        if canUseCore then
            return coreGui
        end
    end

    if LocalPlayer then
        local playerGui = LocalPlayer:FindFirstChildOfClass("PlayerGui")
        if playerGui then
            return playerGui
        end
    end

    return game:GetService("CoreGui")
end

local function raiseOverlay(screen, displayOrder)
    screen.DisplayOrder = displayOrder or Chilly.OverlayDisplayOrder
    pcall(function()
        screen.OnTopOfCoreBlur = true
    end)
    pcall(function()
        screen.ScreenInsets = Enum.ScreenInsets.None
    end)
    pcall(function()
        screen.SafeAreaCompatibility = Enum.SafeAreaCompatibility.None
    end)
end

local function connect(owner, signal, fn)
    local connection = signal:Connect(fn)
    table.insert(owner.Connections, connection)
    return connection
end

local function normalizeKey(key)
    if typeof(key) == "EnumItem" then
        return key
    end
    if type(key) == "string" then
        return Enum.KeyCode[key] or Enum.UserInputType[key]
    end
    return Enum.KeyCode.Unknown
end

local function encode(value)
    local ok, result = pcall(function()
        return HttpService:JSONEncode(value)
    end)
    return ok and result or "{}"
end

local function decode(text)
    local ok, result = pcall(function()
        return HttpService:JSONDecode(text)
    end)
    return ok and type(result) == "table" and result or {}
end

local function canUse(name)
    local env = typeof(getgenv) == "function" and getgenv() or _G
    return type(env[name]) == "function" and env[name]
end

local function clampStep(value, min, max, step)
    value = math.clamp(tonumber(value) or min, min, max)
    step = tonumber(step) or 1
    if step > 0 then
        value = math.floor((value - min) / step + 0.5) * step + min
    end
    return math.clamp(value, min, max)
end

local function asTextList(value)
    if type(value) ~= "table" then
        return {}
    end
    local list = {}
    for _, item in ipairs(value) do
        table.insert(list, tostring(item))
    end
    return list
end

