end

local function parseColor(text, fallback)
    local r, g, b = tostring(text):match("(%d+)%D+(%d+)%D+(%d+)")
    if r and g and b then
        return Color3.fromRGB(math.clamp(tonumber(r), 0, 255), math.clamp(tonumber(g), 0, 255), math.clamp(tonumber(b), 0, 255))
    end
    return fallback
end

function Tab:CreateColorPicker(options)
    options = options or {}
    local color = options.Color or Color3.fromRGB(255, 255, 255)
    local input = self:CreateInput({
        Name = options.Name or "Color",
        CurrentValue = string.format("%d,%d,%d", color.R * 255, color.G * 255, color.B * 255),
        Callback = function(text)
            color = parseColor(text, color)
            call(options.Callback, color)
        end,
    })
    input.Color = color
    function input:Set(newColor)
        color = newColor or color
        self.Color = color
        self.Box.Text = string.format("%d,%d,%d", color.R * 255, color.G * 255, color.B * 255)
        call(options.Callback, color)
    end
    return input
end

