function Chilly:Start(options)
    if #self.Windows > 0 then
        self.Windows[1]:Show()
        return self.Windows[1]
    end
    local window = self:CreateWindow(options or {Name = self.Name})
    window:CreateTab("Main"):CreateLabel("Chilly UI loaded")
    return window
end

