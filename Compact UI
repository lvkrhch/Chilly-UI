local Window = {}
Window.__index = Window

local Tab = {}
Tab.__index = Tab

local function buttonLike(parent, theme, text, height)
    local item = make("TextButton", {
        AutoButtonColor = false,
        Font = Enum.Font.GothamMedium,
        Text = text or "",
        TextSize = 13,
        TextColor3 = theme.Text,
        BackgroundColor3 = theme.Panel2,
        Size = UDim2.new(1, 0, 0, height or 36),
        Parent = parent,
    })
    addCorner(item, 6)
    addStroke(item, theme.Stroke, 0.25)
    return item
end

local function label(parent, theme, text, size, color)
    return make("TextLabel", {
        BackgroundTransparency = 1,
        Font = Enum.Font.Gotham,
        Text = tostring(text or ""),
        TextColor3 = color or theme.Text,
        TextSize = size or 13,
        TextXAlignment = Enum.TextXAlignment.Left,
        TextYAlignment = Enum.TextYAlignment.Center,
        Size = UDim2.new(1, 0, 1, 0),
        Parent = parent,
    })
end

local function component(tab, height)
    local frame = make("Frame", {
        BackgroundColor3 = tab.Theme.Panel,
        Size = UDim2.new(1, 0, 0, height or 44),
        Parent = tab.Page,
    })
    addCorner(frame, 6)
    addStroke(frame, tab.Theme.Stroke, 0.35)
    make("UIPadding", {
        PaddingLeft = UDim.new(0, 10),
        PaddingRight = UDim.new(0, 10),
        PaddingTop = UDim.new(0, 7),
        PaddingBottom = UDim.new(0, 7),
        Parent = frame,
    })
    return frame
end

local function resizeCanvas(page)
    local layout = page:FindFirstChildOfClass("UIListLayout")
    if layout then
        page.CanvasSize = UDim2.new(0, 0, 0, layout.AbsoluteContentSize.Y + 12)
    end
end

local function watchPage(page)
    local layout = make("UIListLayout", {
        Padding = UDim.new(0, 8),
        SortOrder = Enum.SortOrder.LayoutOrder,
        Parent = page,
    })
    make("UIPadding", {
        PaddingLeft = UDim.new(0, 10),
        PaddingRight = UDim.new(0, 10),
        PaddingTop = UDim.new(0, 10),
        PaddingBottom = UDim.new(0, 10),
        Parent = page,
    })
    layout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
        resizeCanvas(page)
    end)
end

function Chilly:CreateWindow(options)
    options = type(options) == "table" and options or {Name = tostring(options or self.Name)}
    local theme = buildTheme(options.Theme or options.ThemeName or "Graphite")
    local screen = make("ScreenGui", {
        Name = options.Name or "Chilly",
        ResetOnSpawn = false,
        IgnoreGuiInset = true,
        DisplayOrder = options.DisplayOrder or self.OverlayDisplayOrder,
        ZIndexBehavior = Enum.ZIndexBehavior.Sibling,
        Parent = options.Parent or getParent(options.PreferPlayerGui),
    })
    raiseOverlay(screen, options.DisplayOrder or self.OverlayDisplayOrder)

    local root = make("Frame", {
        AnchorPoint = Vector2.new(0.5, 0.5),
        Active = true,
        Position = options.Position or UDim2.fromScale(0.5, 0.5),
        Size = options.Size or UDim2.fromOffset(560, 390),
        BackgroundColor3 = theme.Background,
        Parent = screen,
    })
    addCorner(root, 8)
    addStroke(root, theme.Stroke, 0.05)

    local titleBar = make("Frame", {
        Active = true,
        BackgroundColor3 = theme.Panel,
        Size = UDim2.new(1, 0, 0, 42),
        Parent = root,
    })
    addCorner(titleBar, 8)

    local title = make("TextLabel", {
        BackgroundTransparency = 1,
        Font = Enum.Font.GothamBold,
        Text = options.Name or options.Title or self.Name,
        TextColor3 = theme.Text,
        TextSize = 15,
        TextXAlignment = Enum.TextXAlignment.Left,
        Size = UDim2.new(1, -96, 1, 0),
        Position = UDim2.fromOffset(14, 0),
        Parent = titleBar,
    })

    local min = buttonLike(titleBar, theme, "-", 26)
    min.Size = UDim2.fromOffset(28, 26)
    min.Position = UDim2.new(1, -70, 0, 8)
    local close = buttonLike(titleBar, theme, "x", 26)
    close.Size = UDim2.fromOffset(28, 26)
    close.Position = UDim2.new(1, -36, 0, 8)

    local tabList = make("ScrollingFrame", {
        Active = true,
        BackgroundColor3 = theme.Panel,
        BorderSizePixel = 0,
        ScrollBarThickness = 2,
        CanvasSize = UDim2.new(),
        Position = UDim2.fromOffset(10, 52),
        Size = UDim2.new(0, 140, 1, -62),
        Parent = root,
    })
    addCorner(tabList, 6)
    watchPage(tabList)

    local pages = make("Frame", {
        Active = true,
        BackgroundTransparency = 1,
        Position = UDim2.fromOffset(160, 52),
        Size = UDim2.new(1, -170, 1, -62),
        Parent = root,
    })

    local window = setmetatable({
        Chilly = self,
        Screen = screen,
        Root = root,
        Title = title,
        TabList = tabList,
        Pages = pages,
        Tabs = {},
        Connections = {},
        Theme = theme,
        Flags = self.Flags,
        Minimized = false,
        Visible = true,
        NormalSize = root.Size,
        ConfigFolder = options.ConfigurationFolder or options.FolderName or "Chilly",
        ConfigName = options.ConfigurationFile or options.ConfigName or options.Name or "config",
    }, Window)
    table.insert(self.Windows, window)

    local dragging, dragStart, startPos
    local function startDrag(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1
            or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = root.Position
        end
    end
    window.StartDrag = startDrag

    connect(window, root.InputBegan, startDrag)
    connect(window, titleBar.InputBegan, startDrag)
    connect(window, tabList.InputBegan, startDrag)
    connect(window, pages.InputBegan, startDrag)
    connect(window, UserInputService.InputEnded, function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1
            or input.UserInputType == Enum.UserInputType.Touch then
            dragging = false
        end
    end)
    connect(window, UserInputService.InputChanged, function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement
            or input.UserInputType == Enum.UserInputType.Touch) then
            local delta = input.Position - dragStart
            root.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)
    connect(window, UserInputService.InputBegan, function(input, gameProcessed)
        if not gameProcessed and input.KeyCode == Chilly.ToggleUIKeybind then
            window:SetVisibility(not window.Visible)
        end
    end)
    connect(window, close.MouseButton1Click, function()
        window:Destroy()
    end)
    connect(window, min.MouseButton1Click, function()
        window:ToggleMaximize()
    end)

    if options.LoadingTitle or options.LoadingSubtitle then
        self:Notify({
            Title = options.LoadingTitle or options.Name or "Chilly",
            Content = options.LoadingSubtitle or "Loaded",
            Duration = 2,
        })
    end

    return window
end

function Chilly:CreateLib(name, theme)
    return self:CreateWindow({Name = name or self.Name, Theme = theme})
end

function Chilly:CreateProfessionalWindow(options)
    return self:CreateWindow(options or {})
end

function Chilly:ApplyProfessionalDefaults(options)
    options = options or {}
    options.Theme = options.Theme or "Graphite"
    options.Size = options.Size or UDim2.fromOffset(580, 410)
    return options
end

function Window:GetConfigPath()
    return tostring(self.ConfigFolder) .. "/" .. tostring(self.ConfigName) .. ".json"
end

function Window:SaveConfiguration()
    local writefile = canUse("writefile")
    local makefolder = canUse("makefolder")
    local isfolder = canUse("isfolder")
    if not writefile then
        return false
    end
    if makefolder and (not isfolder or not isfolder(self.ConfigFolder)) then
        pcall(makefolder, self.ConfigFolder)
    end
    pcall(writefile, self:GetConfigPath(), encode(self.Flags))
    return true
end

function Window:LoadConfiguration()
    local readfile = canUse("readfile")
    local isfile = canUse("isfile")
    if not readfile or (isfile and not isfile(self:GetConfigPath())) then
        return false
    end
    for key, value in pairs(decode(readfile(self:GetConfigPath()))) do
        self.Flags[key] = value
    end
    return true
end

function Window:SetVisibility(visible)
    self.Visible = visible ~= false
    self.Screen.Enabled = self.Visible
end

function Window:IsVisible()
    return self.Visible
end

function Window:Hide()
    self:SetVisibility(false)
end

function Window:Show()
    self:SetVisibility(true)
end

function Window:ToggleMaximize()
    self.Minimized = not self.Minimized
    self.Pages.Visible = not self.Minimized
    self.TabList.Visible = not self.Minimized
    tween(self.Root, {Size = self.Minimized and UDim2.fromOffset(360, 42) or self.NormalSize}, 0.18)
end

function Window:SetTitle(text)
    self.Title.Text = tostring(text or "")
end

function Window:Notify(options)
    return self.Chilly:Notify(options)
end

function Window:Destroy()
    for _, connection in ipairs(self.Connections) do
        pcall(function()
            connection:Disconnect()
        end)
    end
    self.Screen:Destroy()
    local index = table.find(self.Chilly.Windows, self)
    if index then
        table.remove(self.Chilly.Windows, index)
    end
end

function Window:ModifyTheme(theme)
    self.Theme = buildTheme(theme)
    return self.Theme
end

function Window:CreateTab(name, icon)
    local tabButton = buttonLike(self.TabList, self.Theme, tostring(name or "Tab"), 34)
    local page = make("ScrollingFrame", {
        Active = true,
        BackgroundTransparency = 1,
        BorderSizePixel = 0,
        ScrollBarThickness = 3,
        Size = UDim2.fromScale(1, 1),
        CanvasSize = UDim2.new(),
        Visible = false,
        Parent = self.Pages,
    })
    watchPage(page)

    local tab = setmetatable({
        Window = self,
        Name = tostring(name or "Tab"),
        Icon = icon,
        Button = tabButton,
        Page = page,
        Theme = self.Theme,
        Flags = self.Flags,
    }, Tab)
    table.insert(self.Tabs, tab)

    connect(self, tabButton.MouseButton1Click, function()
        self:SelectTab(tab)
    end)
    if self.StartDrag then
        connect(self, page.InputBegan, self.StartDrag)
    end
    if #self.Tabs == 1 then
        self:SelectTab(tab)
    end
    return tab
end

function Window:NewTab(name, icon)
    return self:CreateTab(name, icon)
end

function Window:SelectTab(tab)
    for _, other in ipairs(self.Tabs) do
        local active = other == tab
        other.Page.Visible = active
        tween(other.Button, {BackgroundColor3 = active and self.Theme.Accent or self.Theme.Panel2}, 0.12)
    end
    self.SelectedTab = tab
end

function Tab:ElementFrame(height)
    return component(self, height)
end

function Tab:CreateSection(name)
    local frame = make("TextLabel", {
        BackgroundTransparency = 1,
        Font = Enum.Font.GothamBold,
        Text = tostring(name or "Section"),
        TextColor3 = self.Theme.Muted,
        TextSize = 12,
        TextXAlignment = Enum.TextXAlignment.Left,
        Size = UDim2.new(1, 0, 0, 24),
        Parent = self.Page,
    })
    local object = {Frame = frame}
    function object:Set(text)
        frame.Text = tostring(text or "")
    end
    return object
end

function Tab:NewSection(name)
    return self:CreateSection(name)
end

function Tab:CreateDivider()
    local frame = make("Frame", {
        BackgroundColor3 = self.Theme.Stroke,
        BorderSizePixel = 0,
        Size = UDim2.new(1, 0, 0, 1),
        Parent = self.Page,
    })
    return {Frame = frame, Set = function(_, visible) frame.Visible = visible ~= false end}
end

function Tab:CreateLabel(text, icon, color)
    local frame = component(self, 36)
    local textLabel = label(frame, self.Theme, text, 13, color)
    local object = {Frame = frame, Label = textLabel}
    function object:Set(newText, _, newColor)
        textLabel.Text = tostring(newText or "")
        if newColor then
            textLabel.TextColor3 = newColor
        end
    end
    return object
end

function Tab:NewLabel(text, icon, color)
    return self:CreateLabel(text, icon, color)
end

function Tab:CreateParagraph(options)
    options = options or {}
    local frame = component(self, options.Height or 70)
    local title = label(frame, self.Theme, options.Title or options.Name or "Paragraph", 13)
    title.Font = Enum.Font.GothamBold
    title.Size = UDim2.new(1, 0, 0, 20)
    local content = label(frame, self.Theme, options.Content or options.Text or "", 12, self.Theme.Muted)
    content.TextWrapped = true
    content.TextYAlignment = Enum.TextYAlignment.Top
    content.Position = UDim2.fromOffset(0, 24)
    content.Size = UDim2.new(1, 0, 1, -24)
    local object = {Frame = frame, Title = title, Content = content}
    function object:Set(newOptions)
        if type(newOptions) == "table" then
            title.Text = tostring(newOptions.Title or newOptions.Name or title.Text)
            content.Text = tostring(newOptions.Content or newOptions.Text or content.Text)
        else
            content.Text = tostring(newOptions or "")
        end
    end
    return object
end

function Tab:CreateCard(options)
    return self:CreateParagraph(options)
end

function Tab:CreateButton(options)
    options = type(options) == "table" and options or {Name = tostring(options or "Button")}
    local button = buttonLike(self.Page, self.Theme, options.Name or "Button", options.Height or 38)
    connect(self.Window, button.MouseButton1Click, function()
        tween(button, {BackgroundColor3 = self.Theme.Accent}, 0.08)
        task.delay(0.1, function()
            if button.Parent then
                tween(button, {BackgroundColor3 = self.Theme.Panel2}, 0.12)
            end
        end)
        call(options.Callback)
    end)
    local object = {Button = button}
    function object:Set(text)
        button.Text = tostring(text or "")
    end
    return object
end

function Tab:NewButton(name, info, callback)
    return self:CreateButton({Name = name, Callback = callback})
end

function Tab:CreateToggle(options)
    options = options or {}
    local frame = component(self, 42)
    local text = label(frame, self.Theme, options.Name or "Toggle")
    text.Size = UDim2.new(1, -58, 1, 0)
    local switch = make("TextButton", {
        AutoButtonColor = false,
        Text = "",
        BackgroundColor3 = self.Theme.Panel2,
        Position = UDim2.new(1, -46, 0.5, -10),
        Size = UDim2.fromOffset(42, 20),
        Parent = frame,
    })
    addCorner(switch, 10)
    local knob = make("Frame", {
        BackgroundColor3 = self.Theme.Muted,
        Position = UDim2.fromOffset(2, 2),
        Size = UDim2.fromOffset(16, 16),
        Parent = switch,
    })
    addCorner(knob, 8)

    local object = {Frame = frame, CurrentValue = false, Value = false}
    local function paint(value)
        tween(switch, {BackgroundColor3 = value and self.Theme.Accent or self.Theme.Panel2}, 0.12)
        tween(knob, {Position = value and UDim2.fromOffset(24, 2) or UDim2.fromOffset(2, 2)}, 0.12)
    end
    function object:Set(value, callCallback)
        self.CurrentValue = value == true
        self.Value = self.CurrentValue
        if options.Flag then
            Chilly.Flags[options.Flag] = self.CurrentValue
        end
        paint(self.CurrentValue)
        if callCallback ~= false then
            call(options.Callback, self.CurrentValue)
        end
    end
    connect(self.Window, switch.MouseButton1Click, function()
        object:Set(not object.CurrentValue)
    end)
    object:Set(options.CurrentValue or options.Default or false, false)
    return object
end

function Tab:NewToggle(name, info, default, callback)
    return self:CreateToggle({Name = name, CurrentValue = default, Callback = callback})
end

function Tab:CreateSlider(options)
    options = options or {}
    local min = (options.Range and options.Range[1]) or options.Min or 0
    local max = (options.Range and options.Range[2]) or options.Max or 100
    local step = options.Increment or options.Step or 1
    local frame = component(self, 58)
    local name = label(frame, self.Theme, options.Name or "Slider")
    name.Size = UDim2.new(1, -74, 0, 22)
    local valueText = label(frame, self.Theme, "", 12, self.Theme.Muted)
    valueText.TextXAlignment = Enum.TextXAlignment.Right
    valueText.Position = UDim2.new(1, -76, 0, 0)
    valueText.Size = UDim2.fromOffset(76, 22)
    local bar = make("Frame", {
        BackgroundColor3 = self.Theme.Panel2,
        Position = UDim2.new(0, 0, 1, -18),
        Size = UDim2.new(1, 0, 0, 8),
        Parent = frame,
    })
    addCorner(bar, 4)
    local fill = make("Frame", {
        BackgroundColor3 = self.Theme.Accent,
        Size = UDim2.new(0, 0, 1, 0),
        Parent = bar,
    })
    addCorner(fill, 4)

    local object = {Frame = frame, CurrentValue = min}
    local dragging = false
    local function setFromX(x)
        local pct = math.clamp((x - bar.AbsolutePosition.X) / math.max(bar.AbsoluteSize.X, 1), 0, 1)
        object:Set(min + (max - min) * pct)
    end
    function object:Set(value, callCallback)
        value = clampStep(value, min, max, step)
        self.CurrentValue = value
        if options.Flag then
            Chilly.Flags[options.Flag] = value
        end
        local pct = (value - min) / math.max(max - min, 1)
        fill.Size = UDim2.new(pct, 0, 1, 0)
        valueText.Text = tostring(value) .. tostring(options.Suffix or "")
        if callCallback ~= false then
            call(options.Callback, value)
        end
    end
    connect(self.Window, bar.InputBegan, function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            setFromX(input.Position.X)
        end
    end)
    connect(self.Window, UserInputService.InputEnded, function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
        end
    end)
    connect(self.Window, UserInputService.InputChanged, function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            setFromX(input.Position.X)
        end
    end)
    object:Set(options.CurrentValue or options.Default or min, false)
    return object
end

