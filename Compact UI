    local box = make("TextBox", {
        ClearTextOnFocus = false,
        Font = Enum.Font.Gotham,
        PlaceholderText = options.PlaceholderText or options.Placeholder or "",
        Text = tostring(options.CurrentValue or options.Default or ""),
        TextColor3 = self.Theme.Text,
        PlaceholderColor3 = self.Theme.Muted,
        TextSize = 12,
        BackgroundColor3 = self.Theme.Panel2,
        Position = UDim2.new(0.42, 0, 0.5, -15),
        Size = UDim2.new(0.58, 0, 0, 30),
        Parent = frame,
    })
    addCorner(box, 5)
    local object = {Frame = frame, Box = box, CurrentValue = box.Text}
    function object:Set(value, callCallback)
        self.CurrentValue = tostring(value or "")
        box.Text = self.CurrentValue
        if options.Flag then
            Chilly.Flags[options.Flag] = self.CurrentValue
        end
        if callCallback ~= false then
            call(options.Callback, self.CurrentValue)
        end
    end
    connect(self.Window, box.FocusLost, function(enterPressed)
        if options.CallbackOnEnterOnly and not enterPressed then
            object:Set(box.Text, false)
            return
        end
        if options.RemoveTextAfterFocusLost then
            object:Set("")
        else
            object:Set(box.Text)
        end
    end)
    return object
end

