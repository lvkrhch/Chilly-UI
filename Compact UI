function Chilly:Notify(options)
    options = type(options) == "table" and options or {Title = tostring(options or "Notice")}
    local gui = make("ScreenGui", {
        Name = "ChillyNotify",
        ResetOnSpawn = false,
        IgnoreGuiInset = true,
        DisplayOrder = Chilly.OverlayDisplayOrder,
        Parent = getParent(),
    })
    raiseOverlay(gui, Chilly.OverlayDisplayOrder)
    local theme = buildTheme(options.Theme or "Graphite")
    local box = make("Frame", {
        AnchorPoint = Vector2.new(1, 0),
        Position = UDim2.new(1, -18, 0, 18),
        Size = UDim2.fromOffset(280, options.Content and 78 or 50),
        BackgroundColor3 = theme.Panel,
        Parent = gui,
    })
    addCorner(box, 8)
    addStroke(box, theme.Stroke, 0.15)
    make("UIPadding", {
        PaddingLeft = UDim.new(0, 12),
        PaddingRight = UDim.new(0, 12),
        PaddingTop = UDim.new(0, 8),
        PaddingBottom = UDim.new(0, 8),
        Parent = box,
    })
    local title = label(box, theme, options.Title or options.Name or "Chilly", 13)
    title.Font = Enum.Font.GothamBold
    title.Size = UDim2.new(1, 0, 0, 20)
    if options.Content or options.Description then
        local content = label(box, theme, options.Content or options.Description, 12, theme.Muted)
        content.TextWrapped = true
        content.Position = UDim2.fromOffset(0, 24)
        content.Size = UDim2.new(1, 0, 1, -24)
    end
    task.delay(options.Duration or 4, function()
        if gui.Parent then
            gui:Destroy()
        end
    end)
    return gui
end

