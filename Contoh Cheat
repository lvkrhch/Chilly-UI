VisualTab:CreateSection("ESP")

VisualTab:CreateToggle({
    Name = "ESP",
    CurrentValue = false,
    Flag = "Chilly_ESP",
    Callback = function(value)
        espEnabled = value
        if not value then
            for _, object in pairs(espObjects) do
                hideEspObject(object)
            end
        end
    end
})

VisualTab:CreateToggle({
    Name = "Box",
    CurrentValue = false,
    Flag = "Chilly_ESPBox",
    Callback = function(value)
        espBoxes = value
    end
})

VisualTab:CreateToggle({
    Name = "Nametag",
    CurrentValue = false,
    Flag = "Chilly_ESPName",
    Callback = function(value)
        espNames = value
    end
})

VisualTab:CreateToggle({
    Name = "Distance",
    CurrentValue = false,
    Flag = "Chilly_ESPDistance",
    Callback = function(value)
        espDistance = value
    end
})

VisualTab:CreateSlider({
    Name = "ESP Max Distance",
    Range = {50, 3000},
    Increment = 50,
    Suffix = "studs",
    CurrentValue = 750,
    Flag = "Chilly_ESPMaxDistance",
    Callback = function(value)
        espMaxDistance = value
    end
})

VisualTab:CreateColorPicker({
    Name = "ESP Color",
    Color = Color3.fromRGB(80, 220, 255),
    Flag = "Chilly_ESPColor",
    Callback = function(value)
        espColor = value
    end
})

AutoClickTab:CreateSection("Auto Click")

AutoClickTab:CreateToggle({
    Name = "Auto Click",
    CurrentValue = false,
    Flag = "Chilly_AutoClick",
    Callback = function(value)
        autoClickEnabled = value
        autoClickAccumulator = 0
        if value and not VirtualInputManager then
            notify("Chilly", "VirtualInputManager tidak tersedia di executor ini.")
        end
    end
})

AutoClickTab:CreateSlider({
    Name = "Click Interval",
    Range = {10, 1000},
    Increment = 10,
    Suffix = "ms",
    CurrentValue = 50,
    Flag = "Chilly_AutoClickInterval",
    Callback = function(value)
        autoClickInterval = math.max(value, 10) / 1000
    end
})

AutoClickTab:CreateButton({
    Name = "Test Click Once",
    Callback = function()
        if not VirtualInputManager then
            notify("Chilly", "VirtualInputManager tidak tersedia.")
            return
        end

        local mouse = LocalPlayer:GetMouse()
        VirtualInputManager:SendMouseButtonEvent(mouse.X, mouse.Y, 0, true, game, 0)
        VirtualInputManager:SendMouseButtonEvent(mouse.X, mouse.Y, 0, false, game, 0)
        notify("Chilly", "Click test sent.")
    end
})

