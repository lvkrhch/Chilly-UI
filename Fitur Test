    }

    object.Box.BackgroundTransparency = 1

    local stroke = Instance.new("UIStroke")
    stroke.Thickness = 1
    stroke.Color = espColor
    stroke.Transparency = 0.75
    stroke.Parent = object.Box
    object.BoxStroke = stroke

    for index = 1, 8 do
