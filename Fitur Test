function Window:GetConfigPath()
    local settings = self.ConfigurationSaving or {}
    local folder = settings.FolderName or "Chilly"
    local file = settings.FileName or "Config"
    return folder, folder .. "/" .. file .. ".json"
end

function Window:SaveConfiguration()
    if not (self.ConfigurationSaving and self.ConfigurationSaving.Enabled) then
        return
    end
    if not executorSupportsFile() then
        warn("[Chilly] config saving is unavailable in this executor")
        return
    end
    local folder, path = self:GetConfigPath()
    ensureFolder(folder)
    local data = {}
    for flag, value in pairs(Chilly.Flags) do
        data[flag] = serializeValue(value)
    end
    writefile(path, HttpService:JSONEncode(data))
end

function Window:LoadConfiguration()
    if not (self.ConfigurationSaving and self.ConfigurationSaving.Enabled) then
        return
    end
    if not executorSupportsFile() then
        return
    end
    local _, path = self:GetConfigPath()
    if not isfile(path) then
        return
    end
    local ok, decoded = pcall(function()
        return HttpService:JSONDecode(readfile(path))
    end)
    if ok and type(decoded) == "table" then
        for flag, value in pairs(decoded) do
            Chilly.Flags[flag] = deserializeValue(value)
        end
    end
end

function Window:SetVisibility(visible)
    self.Visible = visible == true
    self.Container.Visible = self.Visible
    self.ShowButton.Visible = not self.Visible
end

function Window:IsVisible()
    return self.Visible
end

function Window:Hide()
    self:SetVisibility(false)
end

function Window:Show()
    self:SetVisibility(true)
end

function Window:ToggleMaximize()
    if self.Maximized then
        self.Maximized = false
        if self.PreMaximize then
            tween(self.Container, {
                Position = self.PreMaximize.Position,
                Size = self.PreMaximize.Size,
            }, 0.28, Enum.EasingStyle.Quint)
        end
        return
    end

    self.Maximized = true
    self.PreMaximize = {
        Position = self.Container.Position,
        Size = self.Container.Size,
    }
    local viewport = CurrentCamera and CurrentCamera.ViewportSize or Vector2.new(1280, 720)
    local margin = viewport.X < 700 and 18 or 54
    tween(self.Container, {
        AnchorPoint = Vector2.new(0.5, 0.5),
        Position = UDim2.new(0.5, 0, 0.5, 0),
        Size = UDim2.new(1, -margin * 2, 1, -margin * 2),
    }, 0.3, Enum.EasingStyle.Quint)
end

function Window:SetTitle(title)
    self.Title.Text = tostring(title)
end

function Window:Notify(options)
    Chilly:Notify(options)
end

function Window:Destroy()
    self.Destroyed = true
    if self.Gui then
        self.Gui:Destroy()
    end
end

