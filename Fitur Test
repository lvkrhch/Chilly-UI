            TextColor3 = color or theme.TextColor,
            ImageColor3 = color or theme.TextColor,
            TextSize = 12,
            ZIndex = 4,
            Parent = frame,
        })
    end
    make("TextLabel", {
        Position = UDim2.new(0, textOffset, 0, 0),
        Size = UDim2.new(1, -textOffset - 14, 1, 0),
        BackgroundTransparency = 1,
        Font = Enum.Font.GothamSemibold,
        Text = tostring(text),
        TextColor3 = ignoreTheme and (color or Color3.new(1, 1, 1)) or (color or theme.TextColor),
        TextSize = 13,
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = frame,
    })
    local label = {Frame = frame}
    function label:Set(newText, _, newColor, newIgnoreTheme)
        local child = frame:FindFirstChildOfClass("TextLabel")
        child.Text = tostring(newText)
        child.TextColor3 = newIgnoreTheme and (newColor or Color3.new(1, 1, 1)) or (newColor or theme.TextColor)
    end
    return label
end

