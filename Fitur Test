function Tab:CreateSlider(options)
    options = options or {}
    local window = self.Window
    local flag = options.Flag
    local range = options.Range or {0, 100}
    local min = range[1] or 0
    local max = range[2] or 100
    local increment = options.Increment or 1
    local current = Chilly.Flags[flag] or options.CurrentValue or min
    current = math.clamp(current, min, max)
    flagValue(flag, current)

    local frame = self:ElementFrame(66)
    make("TextLabel", {
        Position = UDim2.new(0, 14, 0, 8),
        Size = UDim2.new(1, -120, 0, 20),
        BackgroundTransparency = 1,
        Font = Enum.Font.GothamSemibold,
        Text = options.Name or "Slider",
        TextColor3 = self.Theme.TextColor,
        TextSize = 13,
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = frame,
    })
    local valueLabel = make("TextLabel", {
        AnchorPoint = Vector2.new(1, 0),
        Position = UDim2.new(1, -14, 0, 8),
        Size = UDim2.new(0, 100, 0, 20),
        BackgroundTransparency = 1,
        Font = Enum.Font.GothamSemibold,
        Text = tostring(current) .. (options.Suffix and (" " .. options.Suffix) or ""),
        TextColor3 = self.Theme.Accent,
        TextSize = 12,
        TextXAlignment = Enum.TextXAlignment.Right,
        Parent = frame,
    })
    local track = make("Frame", {
        Position = UDim2.new(0, 14, 0, 40),
        Size = UDim2.new(1, -28, 0, 7),
        BackgroundColor3 = self.Theme.SecondaryElementBackground,
        Parent = frame,
    }, {corner(10)})
    local fill = make("Frame", {
        Size = UDim2.new((current - min) / (max - min), 0, 1, 0),
        BackgroundColor3 = self.Theme.Accent,
        Parent = track,
    }, {corner(10)})

    local object = {CurrentValue = current, Frame = frame}
    local dragging = false
    local function setFromX(x, call)
        local pct = math.clamp((x - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
        local raw = min + ((max - min) * pct)
        local stepped = math.floor((raw / increment) + 0.5) * increment
        object:Set(math.clamp(stepped, min, max), call)
    end

    function object:Set(value, call)
        object.CurrentValue = math.clamp(value, min, max)
        flagValue(flag, object.CurrentValue)
        local pct = (object.CurrentValue - min) / (max - min)
        valueLabel.Text = tostring(object.CurrentValue) .. (options.Suffix and (" " .. options.Suffix) or "")
        tween(fill, {Size = UDim2.new(pct, 0, 1, 0)}, 0.1)
        if call ~= false then
            safeCall(options.Callback, object.CurrentValue)
            window:SaveConfiguration()
        end
    end

    track.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            setFromX(input.Position.X, true)
        end
    end)
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = false
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            setFromX(input.Position.X, true)
        end
    end)
    task.defer(function()
        safeCall(options.Callback, object.CurrentValue)
    end)
    return object
end

function Tab:CreateInput(options)
