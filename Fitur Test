function Chilly:LoadAssets(assetPack)
    if type(assetPack) ~= "table" then
        return self.Assets
    end
    if assetPack.UseImages ~= nil then
        self.Assets.UseImages = assetPack.UseImages == true
    end
    if assetPack.LucideModel then
        self.Assets.LucideModel = assetPack.LucideModel
    end
    if type(assetPack.Icons) == "table" then
        for key, value in pairs(assetPack.Icons) do
            self.Assets.Icons[key] = value
        end
    end
    if type(assetPack.Images) == "table" then
        for key, value in pairs(assetPack.Images) do
            self.Assets.Images[key] = value
        end
    end
    if assetPack.LogoText then
        self.Assets.LogoText = assetPack.LogoText
    end
    if type(assetPack.Sounds) == "table" then
        for key, value in pairs(assetPack.Sounds) do
            self.Assets.Sounds[key] = value
        end
    end
    return self.Assets
end

function Chilly:LoadLucide(source)
    if self.Lucide then
        return self.Lucide
    end

    local candidate = source
    if candidate == nil then
        candidate = self.Assets.LucideModel
    end

    local moduleScript
    if typeof(candidate) == "Instance" then
        if candidate:IsA("ModuleScript") then
            moduleScript = candidate
        else
            moduleScript = candidate:FindFirstChildWhichIsA("ModuleScript", true)
        end
    elseif type(candidate) == "number" or type(candidate) == "string" then
        local id = tostring(candidate):gsub("rbxassetid://", "")
        local ok, objects = pcall(function()
            return game:GetObjects("rbxassetid://" .. id)
        end)
        if ok and type(objects) == "table" then
            for _, object in ipairs(objects) do
                if object:IsA("ModuleScript") then
                    moduleScript = object
                    break
                end
                moduleScript = object:FindFirstChildWhichIsA("ModuleScript", true)
                if moduleScript then
                    break
                end
            end
        end
    end

    if moduleScript then
        local ok, lucide = pcall(require, moduleScript)
        if ok and type(lucide) == "table" and type(lucide.GetAsset) == "function" then
            self.Lucide = lucide
            return lucide
        end
    end

    return nil
end

