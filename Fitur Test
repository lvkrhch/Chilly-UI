local function chillyClamp01(value)
    return math.clamp(value or 0, 0, 1)
end

local function chillyMixColor(a, b, amount)
    amount = chillyClamp01(amount)
    return Color3.new(a.R + (b.R - a.R) * amount, a.G + (b.G - a.G) * amount, a.B + (b.B - a.B) * amount)
end

local function chillyReadableText(background)
    local luminance = (background.R * 0.2126) + (background.G * 0.7152) + (background.B * 0.0722)
    if luminance > 0.58 then
        return Color3.fromRGB(12, 16, 24)
    end
    return Color3.fromRGB(241, 247, 255)
end

function Chilly:CreateTheme(name, overrides)
    local preset = type(name) == "string" and self.ThemePresets[name] or nil
    local merged = deepMerge(self.Themes.Chilly, preset or {})
    merged = deepMerge(merged, overrides or {})
    merged.TextColor = merged.TextColor or chillyReadableText(merged.Background)
    if type(name) == "string" then
        self.Themes[name] = merged
    end
    return merged
end

function Chilly:GetIcon(name, fallback)
    if name == nil then
        return fallback
    end
    local key = string.lower(tostring(name)):gsub("%s+", "_"):gsub("%-", "_")
    return self.IconCatalog[key] or self.Assets.Icons[key] or fallback or tostring(name)
end

function Chilly:RegisterIcons(icons)
    if type(icons) ~= "table" then
        return self.IconCatalog
    end
    for key, value in pairs(icons) do
        local normalized = string.lower(tostring(key)):gsub("%s+", "_"):gsub("%-", "_")
        self.IconCatalog[normalized] = value
        self.Assets.Icons[normalized] = value
    end
    return self.IconCatalog
end

function Chilly:ApplyProfessionalDefaults(options)
    options = options or {}
    options.Theme = options.Theme or "Graphite"
    options.Size = options.Size or UDim2.new(0, 720, 0, 492)
    options.LoadingDuration = options.LoadingDuration or self.DesignTokens.Motion.Boot
    options.LoadingStages = options.LoadingStages or {
        {Text = "Preparing assets", Progress = 0.22, Delay = 0.08},
        {Text = "Resolving icons", Progress = 0.48, Delay = 0.42},
        {Text = "Building panels", Progress = 0.76, Delay = 0.88},
        {Text = options.LoadingSubtitle or "Ready", Progress = 1, Delay = 1.28},
    }
    return options
end

