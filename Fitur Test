local function parseVector3(text)
    local nums = {}

    for raw in string.gmatch(tostring(text or ""), "[-+]?%d*%.?%d+") do
        local num = tonumber(raw)
        if num then
            table.insert(nums, num)
        end

        if #nums >= 3 then
            break
        end
    end

    if #nums < 3 then
        return nil
    end

    return Vector3.new(nums[1], nums[2], nums[3])
end

