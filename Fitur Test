    local submit = make("TextButton", {
        Position = UDim2.new(0, 0, 1, -46),
        Size = UDim2.new(1, 0, 0, 42),
        BackgroundColor3 = Chilly.Themes.Chilly.Accent,
        Font = Enum.Font.GothamSemibold,
        Text = "Continue",
        TextColor3 = Color3.fromRGB(255, 255, 255),
        TextSize = 14,
        Parent = panel,
    }, {
        corner(8),
    })

    local passed = false
    local done = Instance.new("BindableEvent")
    local function check()
        for _, key in ipairs(keys) do
            if input.Text == key then
                passed = true
                if saveKey and executorSupportsFile() then
                    ensureFolder(folder)
                    writefile(path, input.Text)
                end
                done:Fire()
                return
            end
        end
        input.Text = ""
        input.PlaceholderText = "Wrong key"
        tween(input, {BackgroundColor3 = Color3.fromRGB(56, 20, 32)}, 0.12)
        task.delay(0.4, function()
            if input.Parent then
                tween(input, {BackgroundColor3 = Chilly.Themes.Chilly.InputBackground}, 0.18)
            end
        end)
    end

    submit.MouseButton1Click:Connect(check)
    input.FocusLost:Connect(function(enter)
        if enter then
            check()
        end
    end)

    done.Event:Wait()
    done:Destroy()
    gui:Destroy()
    return passed
end

